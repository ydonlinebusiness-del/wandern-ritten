# ── Datenbank (Neon Postgres) ─────────────────────────────────────────────
# In Vercel: Storage → Neon anlegen, dann diese Variable wird automatisch gesetzt.
# Lokal: Connection-String aus dem Neon-Dashboard kopieren.
DATABASE_URL="postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# ── Vercel Blob (Foto-Speicher) ───────────────────────────────────────────
# In Vercel: Storage → Blob anlegen → Token wird automatisch gesetzt.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

# ── Strava API ────────────────────────────────────────────────────────────
# https://www.strava.com/settings/api  (kostenlose API-App anlegen)
# "Authorization Callback Domain" auf deine Vercel-Domain setzen (ohne https://).
STRAVA_CLIENT_ID="12345"
STRAVA_CLIENT_SECRET="dein_strava_client_secret"

# ── App-Konfiguration ─────────────────────────────────────────────────────
# Basis-URL der App (für OAuth-Redirect). Lokal: http://localhost:3000
APP_BASE_URL="http://localhost:3000"
# Einfaches Passwort-Gate (privat). Beliebig wählen.
APP_PASSWORD="rittner-wanderfreund"
# Geheimnis zum Signieren des Session-Cookies (zufälliger String).
SESSION_SECRET="bitte-langen-zufallsstring-eintragen"

# ── Karte ─────────────────────────────────────────────────────────────────
# Mittelpunkt der Ritten-Karte: "lat,lng,zoom"
NEXT_PUBLIC_RITTEN_CENTER="46.54,11.47,13"
